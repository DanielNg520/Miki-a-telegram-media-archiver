# Copy this file to `.env` and fill in your own values. Never commit `.env`.

# --- Required ---
BOT_TOKEN=123456789:replace-with-your-bot-token
SOURCE_CHAT_ID=-1000000000000
# Initial listening topic. After first run you can switch it live with /source_set
# (stored in the DB, no restart); this value is only the seed.
SOURCE_THREAD_ID=1
ARCHIVE_CHAT_ID=-1000000000000
# Optional: direct attachment forwarding. Multiple sources may share one destination.
# Every destination must first be registered with /topic_register. Seeds the database
# on first run only — afterwards manage pairs live with /forward_add and /forward_remove.
TOPIC_FORWARDING_JSON=[]

# --- Optional: requests routing (defaults to ARCHIVE_CHAT_ID) ---
REQUEST_CHAT_ID=
REQUEST_TOPIC_IDS=
REQUESTER_BOT_IDS=

# --- Storage ---
DATABASE_PATH=var/miki.sqlite3
BACKUP_DIRECTORY=var/backups

# --- Automatic daily backups (verified online snapshots + retention) ---
# NOTE: do NOT put inline "# comments" after a value below. Docker's
# `--env-file` does not strip them, so the value would include the comment text
# and fail validation. Keep comments on their own lines, like these.
BACKUP_DAILY_ENABLED=true
# BACKUP_TIME: 24-hour HH:MM, interpreted as UTC
BACKUP_TIME=03:00
# BACKUP_RETENTION_COUNT: keep the N most recent backups, prune older
BACKUP_RETENTION_COUNT=14

# --- Access control (comma-separated Telegram user IDs) ---
# These are SUPER ADMINS with full authority. Grant limited admins (keyword/hashtag
# + diagnostics only) at runtime with /manager_add — no restart needed.
ADMIN_USER_IDS=

# --- Request limits ---
DEFAULT_REQUEST_LIMIT=20
MAX_REQUEST_LIMIT=100

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console

# --- Sorting / delivery ---
# These are starting values only. Every setting in this section is also
# chat-configurable at runtime with no restart: send /config to Miki to list
# them, /set <key> <value> to change one, /reset <key> to revert to the value
# below. A runtime change always wins over the .env default.
SORT_DRY_RUN=false
SEND_CONFIRMATION=false
ALBUM_FLUSH_DELAY_SECONDS=5
ALBUM_MAX_WAIT_SECONDS=30
# Look-back: when media is posted without a caption and a hashtag-only message
# follows, route that recent media too. The buffer is in-memory, time- and
# count-bounded, and self-cleaning.
LOOKBACK_ENABLED=true
LOOKBACK_TTL_SECONDS=120
LOOKBACK_CAPACITY=5
TELEGRAM_RETRY_ATTEMPTS=3
TELEGRAM_RETRY_BASE_DELAY=0.5
TELEGRAM_RETRY_MAX_DELAY=8
TELEGRAM_BOOTSTRAP_RETRIES=-1
TELEGRAM_DROP_PENDING_UPDATES=false
TELEGRAM_MESSAGES_PER_SECOND=10
JOB_RECOVERY_INTERVAL_SECONDS=60
JOB_RECOVERY_BATCH_SIZE=100
TELEGRAM_STARTUP_CHECKIN_ENABLED=false
TELEGRAM_NOTIFICATION_CHAT_IDS=

# --- Runtime mode ---
# RUN_MODE=polling is simplest for VPS/always-on hosts.
# RUN_MODE=webhook is better for HTTPS web app hosts such as Koyeb/Render.
RUN_MODE=polling
WEBHOOK_URL=
WEBHOOK_LISTEN=0.0.0.0
# WEBHOOK_PORT: host-provided PORT is also accepted when WEBHOOK_PORT is unset
WEBHOOK_PORT=8080
WEBHOOK_PATH=/telegram/webhook
WEBHOOK_SECRET_TOKEN=
WEBHOOK_MAX_CONNECTIONS=40

# --- Webhook self-healing (webhook mode only) ---
# Miki reconciles Telegram's webhook registration on a timer and re-registers it
# when it drifts or Telegram reports delivery errors, so the bot recovers on its
# own from cert blips, proxy restarts, or a lost webhook with no manual action.
WEBHOOK_RECONCILE_ENABLED=true
WEBHOOK_RECONCILE_INTERVAL_SECONDS=120
# Liveness window: only acts on staleness when corroborated by a Telegram-side
# symptom (a recent delivery error), so a quiet source never re-registers.
WEBHOOK_STALE_AFTER_SECONDS=900
# Circuit breaker around self-heal: it backs off (and stops) if re-registration
# does not actually fix the drift, so it can never spin every tick.
WEBHOOK_HEAL_FAILURE_THRESHOLD=3
WEBHOOK_HEAL_RESET_SECONDS=300

# --- Health, monitoring, and diagnostics ---
HEALTH_SERVER_ENABLED=false
HEALTH_LISTEN=127.0.0.1
HEALTH_PORT=8081
SANITY_CHECK_ENABLED=true
SANITY_CHECK_INTERVAL_MINUTES=360
SOURCE_ACTIVITY_CHECK_ENABLED=false
SOURCE_ACTIVITY_WINDOW_HOURS=24
ERROR_REPORTING_DSN=
ERROR_REPORTING_ENVIRONMENT=production
DATABASE_BACKEND=sqlite

# --- Integrations ---
INTEGRATION_CLIENTS_JSON=[]
INTEGRATION_SIGNATURE_TTL=300

# --- Routes (JSON array; see README) ---
ROUTES_JSON=[]
